# Copy this file to .env and fill in your values. Never commit the real .env file.

# Your Discord bot token (from the Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=

# Your bot's Application/Client ID (from Discord Developer Portal -> General Information)
CLIENT_ID=

# The Discord server (guild) ID where this bot will run
GUILD_ID=

# The channel ID where the daily BeReal ping and reveal should be posted
CHANNEL_ID=

# Earliest hour (24h, server local time) the random ping can fire, e.g. 11
PING_WINDOW_START_HOUR=11

# Latest hour (24h, server local time) the random ping can fire, e.g. 21
PING_WINDOW_END_HOUR=21

# Minutes friends have to post before they're marked "late", e.g. 120
POST_TIME_LIMIT_MINUTES=120

# Timezone for scheduling, e.g. America/Chicago
TIMEZONE=America/Chicago
