# Copy this file to .env and fill in your values. Never commit the real .env file.

# Your Discord bot token (from the Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=

# Your bot's Application/Client ID (from Discord Developer Portal -> General Information)
CLIENT_ID=

# The Discord server (guild) ID where this bot will run
GUILD_ID=

# The channel ID where the daily BeReal ping and reveal should be posted
CHANNEL_ID=

# Optional: role ID of your BeReal crew. When set, the daily ping mentions this
# role instead of @everyone, reminders ping only members who haven't posted, and
# the reveal fires early once every member has posted. Requires the "Server
# Members Intent" to be enabled on the Bot page in the Discord Developer Portal.
BEREAL_ROLE_ID=

# Earliest hour (24h, in TIMEZONE) the random ping can fire, e.g. 11
PING_WINDOW_START_HOUR=11

# Latest hour (24h, in TIMEZONE) the random ping can fire, e.g. 21
PING_WINDOW_END_HOUR=21

# Minutes friends have to post before they're marked "late", e.g. 120
POST_TIME_LIMIT_MINUTES=120

# Minutes before the deadline to remind people who haven't posted yet
REMINDER_MINUTES_BEFORE=15

# Minutes the photo-of-the-day vote stays open after the reveal
VOTING_MINUTES=60

# Timezone for scheduling, e.g. America/Chicago
TIMEZONE=America/Chicago
